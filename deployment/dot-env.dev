# mibudge local shell environment
# Copied to .env by `make env`  (run once; edit .env after if needed)
#
# PURPOSE: this file is read by tools that run OUTSIDE docker-compose --
# `uv run manage.py`, `pytest`, linters, `make api-schema`, etc.
# It points at the published ports on localhost, not docker-internal hostnames.
#
# For docker-compose itself, see deployment/local-dev-docker.env which uses
# docker-internal hostnames (postgres, redis) and internal port numbers.
#
# All values below are safe defaults for local development.
# In production every variable must be set explicitly -- see
# deployment/dot-env.example.

# General
# ------------------------------------------------------------------------------
DEBUG=True
DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production
DJANGO_ADMIN_URL=admin/
ADMINISTRATIVE_EMAIL_ADDRESS=admin@mibudge.apricot.com
TIME_ZONE=America/Los_Angeles

# PostgreSQL
# docker-compose publishes postgres on localhost:6432 (avoids the system port)
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://debug:debug@localhost:6432/mibudge

# Redis
# docker-compose publishes redis on localhost:7379 (avoids the system port)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:7379/0
CELERY_BROKER_URL=redis://localhost:7379/1
CELERY_RESULT_BACKEND=redis://localhost:7379/2

# Email (Mailpit, published on localhost:1025)
# ------------------------------------------------------------------------------
EMAIL_HOST=localhost

# SSL Certificates (local dev TLS)
# ------------------------------------------------------------------------------
# `make certs` generates hostname-prefixed cert files in deployment/ssl/ so
# that multiple machines sharing the same filesystem each have their own cert.
# Set these to the filenames (not full paths) within deployment/ssl/.
# If unset, the dev server falls back to ssl_crt.pem / ssl_key.pem.
#
# Example — replace with the output of `hostname`:
# SSL_CERT_FILE=mylaptop.local-ssl_crt.pem
# SSL_KEY_FILE=mylaptop.local-ssl_key.pem

# django-fernet-encrypted-fields
# ------------------------------------------------------------------------------
# Used to derive encryption keys for sensitive fields (e.g. account numbers).
# In production use a strong random value and NEVER commit it.
SALT_KEY=local-dev-salt-key-change-in-production

# Sentry (disabled by default)
# ------------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
