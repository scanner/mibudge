# -*- Mode: Makefile -*-

UV_RUN := uv run
PYTHON_VERSION := $(shell grep 'requires-python' $(ROOT_DIR)/pyproject.toml | grep -oE '[0-9]+\.[0-9]+')

.git/hooks/pre-commit .git/hooks/pre-push: .venv
	@$(UV_RUN) pre-commit install
	@touch .git/hooks/pre-commit .git/hooks/pre-push

clean::
	@find $(ROOT_DIR) -name \*~ -exec rm '{}' +
	@find $(ROOT_DIR) -name \*.pyc -exec rm '{}' +
	@find $(ROOT_DIR) -name __pycache__ -prune -exec rm -fr '{}' +
	@rm -rf build dist *.egg-info .ruff_cache .mypy_cache
	@rm -rf .venv

$(ROOT_DIR)/.python-version: $(ROOT_DIR)/pyproject.toml
	@echo $(PYTHON_VERSION) > $@

$(ROOT_DIR)/.venv: pyproject.toml uv.lock $(ROOT_DIR)/.python-version
	@uv sync
	@touch $@

.venv:: $(ROOT_DIR)/.venv

squeegee: .venv ruff-format mypy
	@$(UV_RUN) ruff check app/ importers/

lint: .venv .git/hooks/pre-commit
	@$(UV_RUN) pre-commit run -a

PY_FILES=$(shell find $(ROOT_DIR)/app/ $(ROOT_DIR)/importers/ -type f -name '*.py' 2>/dev/null)

.ruff_formatted: $(PY_FILES) .venv
	@$(UV_RUN) ruff format app/ importers/
	@touch .ruff_formatted

ruff-format: .ruff_formatted

mypy: .venv
	@$(UV_RUN) mypy app/ importers/
